{
  "id": "books-test",
  "name": "Books to Scrape (TEST)",
  "url": "https://books.toscrape.com",
  "engine": "cheerio",
  "schedule": "0 0 1 1 *",
  "selectors": {
    "items": "article.product_pod",
    "fields": {
      "url":    { "selector": "h3 a", "attr": "href" },
      "title":  { "selector": "h3 a", "attr": "title" },
      "price":  { "selector": ".price_color", "attr": "text" },
      "rating": { "selector": ".star-rating", "attr": "class" }
    }
  },
  "keywords": ["mystery", "travel", "historical"],
  "keywordFields": ["title"],
  "pagination": {
    "type": "url",
    "paramName": "page",
    "maxPages": 1
  }
}
